{
  "name": "@step-cli/agent-sdk",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./*.js": {
      "types": "./src/*.ts",
      "default": "./dist/*.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsdown src --no-config --format esm --clean --sourcemap --platform node -d dist"
  },
  "dependencies": {
    "@step-cli/core": "workspace:*",
    "@step-cli/protocol": "workspace:*",
    "@step-cli/utils": "workspace:*"
  }
}
