{
  "name": "step-realtime-cli",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "step": "bin/step-cli.js"
  },
  "scripts": {
    "dev": "concurrently \"pnpm gateway:watch\" \"pnpm ui:dev\" \"pnpm tui:dev\"",
    "build": "pnpm build:packages && pnpm ui:build && tsdown && node scripts/postbuild.mjs",
    "build:bin": "node scripts/build-binary.mjs",
    "build:bin:bundle": "node scripts/build-binary-bundle.mjs",
    "build:packages": "node scripts/build-packages.mjs",
    "build:packages:stale": "node scripts/build-packages.mjs --stale-only",
    "ui:build": "cd ui && pnpm build",
    "ui:dev": "cd ui && pnpm dev",
    "gateway:watch": "tsx watch --no-clear-screen src/gateway/index.ts",
    "tui:dev": "tsx watch src/index.ts",
    "lint": "oxlint -c .oxlintrc.json --format stylish .",
    "check": "pnpm test && pnpm lint && pnpm dep-guard && pnpm deadcode && pnpm exec tsc --noEmit && pnpm format:check",
    "check:staged-files": "node scripts/check-staged-files.mjs",
    "dep-graph-check": "depcruise --config .dependency-cruiser.cjs src packages apps extensions skills ui/src",
    "dep-guard": "pnpm dep-graph-check && node scripts/check-dependency-guardrails.mjs",
    "deadcode": "knip --config knip.config.ts",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json,yml,yaml}\"",
    "open": "tsx src/gateway/index.ts",
    "prepare": "node scripts/install-git-hooks.mjs",
    "init:all": "bash scripts/setup.sh",
    "setup:silero": "node scripts/setup-silero.mjs",
    "setup:voice": "bash scripts/setup.sh",
    "step": "node scripts/run-step.mjs --stale-only",
    "step:fresh": "node scripts/run-step.mjs --full",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:changed": "vitest run --changed"
  },
  "dependencies": {
    "@opentui/core": "^0.1.90",
    "@opentui/react": "^0.1.90",
    "@step-cli/core": "workspace:*",
    "@step-cli/llm": "workspace:*",
    "@step-cli/mcp": "workspace:*",
    "@step-cli/protocol": "workspace:*",
    "@step-cli/realtime": "workspace:*",
    "@step-cli/realtime-aec": "workspace:*",
    "@step-cli/realtime-voice": "workspace:*",
    "@step-cli/sdk": "workspace:*",
    "@step-cli/skills-builtin": "workspace:*",
    "@step-cli/utils": "workspace:*",
    "commander": "^14.0.2",
    "dotenv": "^16.5.0",
    "react": "^19.2.4",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@opentui/core-darwin-arm64": "0.1.90",
    "@opentui/core-darwin-x64": "0.1.90",
    "@opentui/core-linux-arm64": "0.1.90",
    "@opentui/core-linux-x64": "0.1.90",
    "@opentui/core-win32-x64": "0.1.90",
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.12",
    "@vitest/coverage-v8": "^3.2.6",
    "concurrently": "^9.2.1",
    "dependency-cruiser": "^17.3.9",
    "knip": "^6.0.4",
    "oxlint": "~0.15.15",
    "prettier": "^3.8.1",
    "rolldown": "1.0.0-beta.7",
    "simple-git-hooks": "^2.13.1",
    "ts-prune": "^0.10.3",
    "ts-unused-exports": "^11.0.1",
    "tsdown": "~0.6.10",
    "tsx": "~4.19.4",
    "typescript": "~5.7.3",
    "vitest": "^3.2.0"
  },
  "packageManager": "pnpm@10.17.0",
  "simple-git-hooks": {
    "pre-commit": "pnpm check:staged-files && pnpm lint && pnpm exec tsc --noEmit && pnpm format:check"
  }
}
