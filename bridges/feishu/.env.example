# ── Step-Realtime-Feishu-Bridge Configuration ─────────────────────
# Copy this file to .env and fill in your values.

# Step-Realtime-CLI serve URL
STEP_SERVE_URL=http://127.0.0.1:47123

# Feishu bot credentials (required for Lark SDK WebSocket mode)
# Get these from https://open.feishu.cn/app
STEP_FEISHU_APP_ID=cli_xxxxxxxxxxxx
STEP_FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxx

# StepFun API key (for ASR/TTS voice features)
STEP_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxx

# Bridge HTTP server binding
STEP_FEISHU_BIND_HOST=127.0.0.1
STEP_FEISHU_BIND_PORT=18944

# Directory for persistent state (sessions, processed message IDs)
STEP_FEISHU_STATE_DIR=./state

# Working directory for lark-cli tool execution
STEP_FEISHU_WORKDIR=.

# Lark CLI binary path (leave as "lark-cli" if in PATH)
# STEP_FEISHU_LARK_CLI=lark-cli

# Feishu domain: "feishu" (China) or "overseas" (for Lark)
# STEP_FEISHU_DOMAIN=feishu

# Request timeout for Step serve API calls (ms)
# STEP_FEISHU_TIMEOUT_MS=180000

# Disable proxy for lark-cli connections (recommended)
LARK_CLI_NO_PROXY=1
