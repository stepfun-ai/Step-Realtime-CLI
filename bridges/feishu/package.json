{
  "name": "step-realtime-feishu-bridge",
  "version": "1.0.0",
  "private": true,
  "description": "Feishu (Lark) bot bridge for Step-Realtime-CLI — drive CLI programming via Feishu voice/text messages",
  "main": "direct_bridge.cjs",
  "scripts": {
    "start": "node direct_bridge.cjs",
    "dev": "node --watch direct_bridge.cjs",
    "health": "curl -s http://127.0.0.1:18944/health | node -e \"process.stdin.resume();process.stdin.on('data',d=>console.log(JSON.stringify(JSON.parse(d),null,2)))\"",
    "install-launchd": "bash install-launchd.sh"
  },
  "keywords": [
    "feishu",
    "lark",
    "step-cli",
    "bot",
    "bridge"
  ],
  "license": "MIT",
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.66.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
