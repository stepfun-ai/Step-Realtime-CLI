{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "ignoreDeprecations": "5.0",
    "baseUrl": ".",
    "paths": {
      "@step-cli/core": ["packages/core/src/index.ts"],
      "@step-cli/core/*": ["packages/core/src/*"],
      "@step-cli/llm": ["extensions/llm/src/index.ts"],
      "@step-cli/llm/*": ["extensions/llm/src/*"],
      "@step-cli/mcp": ["extensions/mcp/src/index.ts"],
      "@step-cli/mcp/*": ["extensions/mcp/src/*"],
      "@step-cli/sdk": ["packages/sdk/src/index.ts"],
      "@step-cli/sdk/*": ["packages/sdk/src/*"],
      "@step-cli/agent-sdk": ["packages/agent-sdk/src/index.ts"],
      "@step-cli/agent-sdk/*": ["packages/agent-sdk/src/*"],
      "@step-cli/protocol": ["packages/protocol/src/index.ts"],
      "@step-cli/protocol/*": ["packages/protocol/src/*"],
      "@step-cli/realtime": ["packages/realtime/src/index.ts"],
      "@step-cli/realtime/*": ["packages/realtime/src/*"],
      "@step-cli/realtime-aec": ["extensions/realtime-aec/src/index.ts"],
      "@step-cli/realtime-aec/*": ["extensions/realtime-aec/src/*"],
      "@step-cli/realtime-voice": ["extensions/realtime-voice/src/index.ts"],
      "@step-cli/realtime-voice/*": ["extensions/realtime-voice/src/*"],
      "@step-cli/realtime-vad-silero": [
        "extensions/realtime-vad-silero/src/index.ts"
      ],
      "@step-cli/realtime-vad-silero/*": [
        "extensions/realtime-vad-silero/src/*"
      ],
      "@step-cli/skills-builtin": ["skills/builtin/src/index.ts"],
      "@step-cli/skills-builtin/*": ["skills/builtin/src/*"],
      "@step-cli/utils": ["packages/utils/src/index.ts"],
      "@step-cli/utils/*": ["packages/utils/src/*"]
    },
    "outDir": "dist",
    "declaration": true
  },
  "include": [
    "src",
    "packages/*/src",
    "apps/*/src",
    "extensions/*/src",
    "skills/*/src",
    "tests"
  ],
  "exclude": ["dist", "node_modules"]
}
